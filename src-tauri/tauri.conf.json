{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mac-touchpad",
  "identifier": "xiao.luy.mac-touchpad",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "MacTouchpad 设置",
        "width": 880,
        "height": 640,
        "resizable": true,
        "minWidth": 700,
        "minHeight": 500,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
